{
  "name": "petaterm",
  "version": "0.1.0",
  "description": "Claude Code-friendly tabbed terminal for Ubuntu",
  "main": "./out/main/index.js",
  "license": "MIT",
  "author": "denzow",
  "scripts": {
    "dev": "electron-vite dev -- --no-sandbox",
    "build": "electron-vite build",
    "start": "electron-vite preview -- --no-sandbox",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "postinstall": "electron-builder install-app-deps",
    "package": "electron-vite build && electron-builder --linux"
  },
  "build": {
    "appId": "dev.denzow.petaterm",
    "productName": "petaterm",
    "files": [
      "out/**",
      "resources/**"
    ],
    "extraResources": [
      {
        "from": "resources/petaterm-hook.js",
        "to": "petaterm-hook.js"
      }
    ],
    "linux": {
      "target": "AppImage",
      "category": "TerminalEmulator"
    }
  },
  "dependencies": {
    "node-pty": "^1.1.0",
    "simple-git": "^3.36.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^7.0.2",
    "vite": "^7.3.6",
    "zustand": "^5.0.14"
  }
}
